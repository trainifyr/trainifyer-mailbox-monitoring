# Server
PORT=5000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL Direct Connection
# Use the Supabase TRANSACTION POOLER (port 6543) for free-tier connection limits.
# Find it at: Supabase Dashboard -> Project Settings -> Database -> Connection string -> Transaction pooler
# Example: postgresql://postgres:<password>@<host>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:6543/postgres
